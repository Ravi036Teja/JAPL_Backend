# backend/.env.production (for production)

PORT=5000 # Or whatever port your production server listens on (often 80 or 443 via proxy)
MONGODB_URI='YOUR_PRODUCTION_MONGODB_URI' # Use a separate, dedicated production DB
JWT_SECRET='A_VERY_LONG_AND_COMPLEX_PRODUCTION_SECRET_KEY' # Generate a new, strong secret

# Frontend URLs for CORS (production)
# Replace with your actual deployed frontend domains
CORS_ORIGIN=https://www.janatha-automobiles.com,https://admin.janatha-automobiles.com